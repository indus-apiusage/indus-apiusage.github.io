{
  "name": "foropencode-usage-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Scrape ForOpenCode usage logs, aggregate daily usage by API key name, and publish a GitHub Pages dashboard.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "sync": "node ./scripts/sync-usage-data.mjs",
    "sync:publish": "bash ./scripts/sync-and-push.sh",
    "sync:placeholder": "node ./scripts/sync-usage-data.mjs --placeholder",
    "test": "node --test"
  },
  "dependencies": {
    "luxon": "^3.7.1"
  }
}
